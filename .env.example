# ─── BASE DE DONNÉES (Neon Postgres) ──────────────────────────────────────────
# Récupérez depuis votre dashboard Neon : https://console.neon.tech
DATABASE_URL="postgresql://username:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── AUTHENTIFICATION (NextAuth v5) ───────────────────────────────────────────
# Générez avec : openssl rand -base64 32
NEXTAUTH_SECRET="votre-secret-super-securise-minimum-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ─── GOOGLE OAuth (optionnel) ─────────────────────────────────────────────────
# Créez depuis : https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# ─── EMAIL (Resend) ───────────────────────────────────────────────────────────
# Créez depuis : https://resend.com → API Keys
RESEND_API_KEY="re_xxx"
RESEND_FROM_EMAIL="rh@amsode.ml"

# ─── NOTIFICATIONS TEMPS RÉEL (Pusher - plan gratuit) ─────────────────────────
# Créez depuis : https://pusher.com → Channels
PUSHER_APP_ID="your_app_id"
PUSHER_KEY="your_key"
PUSHER_SECRET="your_secret"
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY="your_key"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# ─── STOCKAGE FICHIERS (Vercel Blob ou Cloudinary) ───────────────────────────
# Option 1 : Vercel Blob (recommandé si déployé sur Vercel)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxx"

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="AMSODE RH PRO"
NODE_ENV="development"
